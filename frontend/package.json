{
  "name": "botc-ai-mvp-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --configLoader runner --host 127.0.0.1",
    "build": "tsc -b && vite build --configLoader runner",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --configLoader runner --environment jsdom",
    "smoke": "vitest run --configLoader runner --environment jsdom src/test/smoke.test.tsx"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^15.0.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.3.0",
    "typescript-eslint": "^8.61.1",
    "vitest": "^3.0.0"
  }
}
